# Postgres
POSTGRES_DB=usc_sched
POSTGRES_USER=uscuser
POSTGRES_PASSWORD=uscpass

# API auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS allowlist (comma-separated)
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Semester (optional override)
SEMESTER=20253
