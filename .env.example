# Postgres (bundled container)
# These are used only by the dockerized Postgres service
POSTGRES_DB=usc_sched
POSTGRES_USER=uscuser
POSTGRES_PASSWORD=uscpass

# API database connection (can point to an existing DB)
USC_DB_HOST=db
USC_DB_PORT=5432
USC_DB_NAME=usc_sched
USC_DB_USER=uscuser
USC_DB_PASSWORD=uscpass
# Optional: if your tables are in a non-public schema, set it here (comma-separated allowed)
# USC_DB_SCHEMA=myschema

# API auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# CORS allowlist (comma-separated)
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Semester (optional override)
SEMESTER=20253
